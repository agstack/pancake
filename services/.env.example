# Required: Ed25519 issuer signing key (base64url 32-byte seed or PEM).
# Generate with:
#   python -m pancake_services.grants.testkit.mint_test_credentials --keygen
# Custody: env var for the sprint, vault/KMS before production (PC-2026-0005).
PANCAKE_ISSUER_KEY=

# AR hub integration
HUB_JWKS_URL=http://localhost:8000/.well-known/jwks.json
HUB_URL=

# Public URI embedded in credentials' status claim
STATUS_LIST_URI=http://localhost:8100/grants/status-list

# Postgres (docker-compose)
POSTGRES_PASSWORD=change-me

# TAP vendor credentials (referenced from vendor YAML as ${VAR})
TERRAPIPE_SECRET=
TERRAPIPE_CLIENT=
