# Copy to .env (make demo does this for you) and fill in as needed.
# Secrets are never committed; this file only documents the variables.

# --- Postgres (Pancake) ---
POSTGRES_PASSWORD=pancake-dev-only

# --- Pancake grants issuer (generated by `make keys`) ---
# PEM contents of the Ed25519/RSA issuer private key. Do NOT commit the real value.
PANCAKE_ISSUER_KEY=
PANCAKE_ISSUER_ID=did:web:pancake.local

# --- Trust wiring ---
# Hub JWKS the grants service and node verify hub tokens against.
HUB_JWKS_URL=http://hub:8000/.well-known/jwks.json
HUB_URL=http://hub:8000
STATUS_LIST_URI=http://pancake-grants:8100/grants/status-list

# --- Pancake TAP worker ---
# Path (inside the container) to the vendor config. Defaults to the bundled file.
TAP_VENDORS_CONFIG=/app/dpi-demo/tap_vendors.yaml
# TerraPipe credentials. Leave blank to use the offline `seed` adapter.
TERRAPIPE_BASE_URL=https://appserver.terrapipe.io
TERRAPIPE_SECRET=
TERRAPIPE_CLIENT=
TERRAPIPE_EMAIL=
TERRAPIPE_PASSWORD=

# --- Optional: grant-gate weather BITE reads (WS1) ---
# When true, GET /bites for weather_* types requires a valid X-Field-Grant.
PANCAKE_REQUIRE_GRANT_FOR_WEATHER=false

# --- agstack-pnd ---
PND_WEATHER_PROVIDER=dpi
PND_PANCAKE_URL=http://pancake-grants:8100
PND_AGSTACK_REGISTRY_URL=http://node:8001
# NOAA token only needed if PND_WEATHER_PROVIDER=noaa
PND_NOAA_API_TOKEN=
